<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BenchBase">
    <defName>EI_HandQuern</defName>
    <label>hand quern</label>
    <description>A compact, unpowered quern for milling oats into a prepared cooking ingredient.</description>
    <thingClass>Building_WorkTable</thingClass>
    <graphicData>
      <texPath>Things/Building/Production/HandQuern/EI_HandQuern</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <damageData>
        <rect>(0.2,0,0.6,0.6)</rect>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Production/HandQuern/EI_HandQuern_MenuIcon</uiIconPath>
    <costStuffCount>25</costStuffCount>
    <costList>
      <WoodLog>10</WoodLog>
    </costList>
    <stuffCategories>
      <li>Stony</li>
    </stuffCategories>
    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>0.20</fillPercent>
    <useHitPoints>True</useHitPoints>
    <statBases>
      <WorkToBuild>600</WorkToBuild>
      <MaxHitPoints>90</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Mass>12</Mass>
    </statBases>
    <size>(1,1)</size>
    <designationCategory>Production</designationCategory>
    <uiOrder>2090</uiOrder>
    <passability>Standable</passability>
    <pathCost>14</pathCost>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <surfaceType>Item</surfaceType>
    <inspectorTabs>
      <li>ITab_Bills</li>
    </inspectorTabs>
    <building>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <workTableRoomRole>Workshop</workTableRoomRole>
      <workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
    </building>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
      <li>PlaceWorker_ReportWorkSpeedPenalties</li>
    </placeWorkers>
  </ThingDef>

</Defs>
