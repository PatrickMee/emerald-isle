<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>EI_CentralHearth</defName>
    <label>central hearth</label>
    <description>A permanent stone-lined household hearth for simple cooking, warmth, and light. It burns wood continuously and cooks more slowly than a dedicated stove.</description>
    <thingClass>Building_WorkTable</thingClass>
    <category>Building</category>
    <graphicData>
      <texPath>Things/Building/Temperature/CentralHearth/EI_CentralHearth</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawRotated>false</drawRotated>
      <allowFlip>false</allowFlip>
      <drawSize>(2,1)</drawSize>
      <damageData>
        <rect>(0.1,0,0.8,0.2)</rect>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Temperature/CentralHearth/EI_CentralHearth_MenuIcon</uiIconPath>
    <uiIconScale>0.95</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <fillPercent>0.35</fillPercent>
    <rotatable>false</rotatable>
    <size>(2,1)</size>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <MaxHitPoints>160</MaxHitPoints>
      <WorkToBuild>1200</WorkToBuild>
      <Flammability>0</Flammability>
      <WorkTableWorkSpeedFactor>0.45</WorkTableWorkSpeedFactor>
      <Mass>35</Mass>
    </statBases>
    <costStuffCount>60</costStuffCount>
    <costList>
      <WoodLog>20</WoodLog>
    </costList>
    <stuffCategories>
      <li>Stony</li>
    </stuffCategories>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <selectable>true</selectable>
    <soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
      <li>PlaceWorker_Heater</li>
      <li>PlaceWorker_GlowRadius</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>8.0</fuelConsumptionRate>
        <fuelCapacity>32.0</fuelCapacity>
        <fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
        <fuelFilter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </fuelFilter>
        <initialFuelPercent>1</initialFuelPercent>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <functionsInVacuum>false</functionsInVacuum>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>9</glowRadius>
        <glowColor>(252,187,113,0)</glowColor>
      </li>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>16</heatPerSecond>
        <heatPushMaxTemperature>26</heatPushMaxTemperature>
      </li>
      <li Class="CompProperties_FireOverlay">
        <fireSize>0.85</fireSize>
      </li>
      <li>
        <compClass>CompGatherSpot</compClass>
      </li>
    </comps>
    <designationCategory>Temperature</designationCategory>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <recipes>
      <li>CookMealSimple</li>
      <li>CookMealSimpleBulk</li>
      <li>Make_Pemmican</li>
      <li>Make_PemmicanBulk</li>
      <li>EI_CookOatPorridge</li>
      <li>EI_CookOatFlatbread</li>
      <li>BurnApparel</li>
      <li>BurnWeapon</li>
      <li>BurnDrugs</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFood</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">Make_BabyFoodBulk</li>
    </recipes>
    <inspectorTabs>
      <li>ITab_Bills</li>
    </inspectorTabs>
    <building>
      <isMealSource>true</isMealSource>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <destroySound>BuildingDestroyed_Stone_Small</destroySound>
    </building>
  </ThingDef>

</Defs>
