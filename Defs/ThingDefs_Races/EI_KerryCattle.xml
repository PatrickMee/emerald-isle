<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>EI_KerryCattle</defName>
    <label>Kerry cattle</label>
    <description>A small, hardy dairy breed adapted to making the most of limited pasture. Compared with standard cows, Kerry cattle eat less and withstand colder weather, but each cow gives less milk and the smaller body yields less meat. Matching a standard cow's output takes more animals and more milking work.</description>
    <statBases>
      <MoveSpeed>3.2</MoveSpeed>
      <ComfyTemperatureMin>-30</ComfyTemperatureMin>
      <MarketValue>240</MarketValue>
      <FilthRate>16</FilthRate>
      <Wildness>0</Wildness>
    </statBases>
    <uiIconScale>1.15</uiIconScale>
    <comps>
      <li Class="CompProperties_Milkable">
        <milkDef>Milk</milkDef>
        <milkIntervalDays>1</milkIntervalDays>
        <milkAmount>9</milkAmount>
      </li>
    </comps>
    <race>
      <body>QuadrupedAnimalWithHooves</body>
      <herdAnimal>true</herdAnimal>
      <baseBodySize>1.6</baseBodySize>
      <baseHungerRate>0.32</baseHungerRate>
      <baseHealthScale>1.15</baseHealthScale>
      <foodType>VegetarianRoughAnimal</foodType>
      <leatherDef>Leather_Plain</leatherDef>
      <roamMtbDays>2</roamMtbDays>
      <trainability>None</trainability>
      <meatLabel>Kerry beef</meatLabel>
      <gestationPeriodDays>6.66</gestationPeriodDays>
      <lifeExpectancy>22</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.20</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.3333</minAge>
          <soundWounded>Pawn_Muffalo_Wounded</soundWounded>
          <soundDeath>Pawn_Muffalo_Death</soundDeath>
          <soundCall>Pawn_Muffalo_Call</soundCall>
          <soundAngry>Pawn_Muffalo_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
      <soundEating>Herbivore_Eat</soundEating>
      <headPosPerRotation>
        <li>(0.0, 0, 0.08)</li>
        <li>(0.24, 0, 0)</li>
        <li>(0.0, 0, -0.04)</li>
        <li>(-0.24, 0, 0)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
      <li>AnimalCommon</li>
      <li>AnimalFarm</li>
    </tradeTags>
    <tools>
      <li>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>7.2</power>
        <cooldownTime>2.6</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
      <li>
        <label>left hoof</label>
        <labelNoLocation>hoof</labelNoLocation>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>7</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
      </li>
      <li>
        <label>right hoof</label>
