    <soundWorking>Recipe_CookMeal</soundWorking>
    <workSkill>Cooking</workSkill>
    <recipeUsers>
      <li>Campfire</li>
      <li>FueledStove</li>
      <li>ElectricStove</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>EI_MilledOats</li>
