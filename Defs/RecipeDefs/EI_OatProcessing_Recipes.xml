<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <RecipeDef>
    <defName>EI_MillOats</defName>
    <label>mill oats</label>
    <description>Mill raw oats into a prepared cooking ingredient.</description>
    <jobString>Milling oats.</jobString>
    <workAmount>180</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <requiredGiverWorkType>Crafting</requiredGiverWorkType>
    <effectWorking>CutStone</effectWorking>
    <soundWorking>Recipe_MakeStoneBlocks</soundWorking>
    <targetCountAdjustment>10</targetCountAdjustment>
    <workSkill>Crafting</workSkill>
    <workSkillLearnFactor>0</workSkillLearnFactor>
    <recipeUsers>
      <li>EI_HandQuern</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>EI_RawOats</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>EI_RawOats</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EI_MilledOats>10</EI_MilledOats>
    </products>
  </RecipeDef>

